<ui:FluentWindow x:Class="Resumenes.Ui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vistas="clr-namespace:Resumenes.Ui.Vistas"
    Title="Resúmenes de Estudio"
    Icon="/Recursos/app.ico"
    Width="1100" Height="720"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0" Title="Resúmenes de Estudio">
      <ui:TitleBar.Icon>
        <ui:ImageIcon Source="/Recursos/app.ico" Width="20" Height="20" />
      </ui:TitleBar.Icon>
    </ui:TitleBar>

    <ui:NavigationView x:Name="Nav" Grid.Row="1" PaneDisplayMode="Left" IsBackButtonVisible="Collapsed">
      <ui:NavigationView.MenuItems>
        <ui:NavigationViewItem Content="Inicio"
            TargetPageType="{x:Type vistas:VistaInicio}">
          <ui:NavigationViewItem.Icon>
            <ui:SymbolIcon Symbol="Home24" />
          </ui:NavigationViewItem.Icon>
        </ui:NavigationViewItem>
        <ui:NavigationViewItem Content="Configuración"
            TargetPageType="{x:Type vistas:VistaConfiguracion}">
          <ui:NavigationViewItem.Icon>
            <ui:SymbolIcon Symbol="Settings24" />
          </ui:NavigationViewItem.Icon>
        </ui:NavigationViewItem>
      </ui:NavigationView.MenuItems>
    </ui:NavigationView>

    <!-- Host de diálogos modales (ContentDialog): overlay con velo sobre toda la ventana -->
    <ContentPresenter x:Name="PresentadorDialogos" Grid.Row="0" Grid.RowSpan="2"/>
  </Grid>
</ui:FluentWindow>
