<ui:FluentWindow
    x:Class="Resumenes.Ui.Vistas.VentanaActivacion"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Resumenes.Ui.ViewModels"
    Title="Resúmenes — Activación" Width="560" Height="660"
    WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <vm:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <vm:StringToVisibilityConverter x:Key="StrToVis"/>
    </ui:FluentWindow.Resources>
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Activá tu licencia" FontSize="24" FontWeight="Bold"/>
        <TextBlock Grid.Row="1" Margin="0,8,0,16" TextWrapping="Wrap"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="Ingresá la clave que recibiste para desbloquear la app en este equipo."/>

        <ui:TextBox Grid.Row="2" PlaceholderText="RESU-XXXXX-XXXXX-XXXXX-XXXXX"
                    Text="{Binding Clave, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    FontSize="16" Margin="0,0,0,12"/>

        <ui:Button Grid.Row="3" Content="Activar" Appearance="Primary" HorizontalAlignment="Left"
                   Command="{Binding ActivarCommand}"
                   Visibility="{Binding Activando, Converter={StaticResource InvBoolToVis}}"
                   Icon="{ui:SymbolIcon Symbol=Key24}"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left"
                    Visibility="{Binding Activando, Converter={StaticResource BoolToVis}}">
            <ui:ProgressRing IsIndeterminate="True" Width="22" Height="22"/>
            <TextBlock Text="Activando…" Margin="8,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <ui:InfoBar Grid.Row="4" Margin="0,12,0,0" Severity="Error" IsOpen="True"
                    Visibility="{Binding MensajeError, Converter={StaticResource StrToVis}}"
                    Title="No se pudo activar" Message="{Binding MensajeError}"/>

        <!-- Disclaimer: cómo conseguir la clave + requisito de Deepseek -->
        <Border Grid.Row="5" Margin="0,20,0,0" Padding="16" CornerRadius="8"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="¿No tenés una clave?"/>
                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <Run Text="Escribime para conseguirla:   "/>
                    <Hyperlink NavigateUri="mailto:emmavz@live.com" RequestNavigate="AbrirEnlace">emmavz@live.com</Hyperlink>
                    <Run Text="    ·    WhatsApp "/>
                    <Hyperlink NavigateUri="https://wa.me/5491159459241" RequestNavigate="AbrirEnlace">11 5945-9241</Hyperlink>
                </TextBlock>
                <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Text="Importante: además de la clave, la app usa inteligencia artificial (Deepseek) para los resúmenes y los exámenes. Para que funcione necesitás una cuenta de Deepseek con saldo (desde unos US$2), que cargás vos en tu propia cuenta. La app no cobra ese saldo."/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="6" VerticalAlignment="Bottom" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                   Text="{Binding IdEquipo, StringFormat='ID de equipo: {0}'}"/>
    </Grid>
</ui:FluentWindow>
