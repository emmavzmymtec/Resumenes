<Page x:Class="Resumenes.Ui.Vistas.VistaConfiguracion"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Resumenes.Ui.ViewModels"
      Title="Configuración">

  <Page.Resources>
    <vm:StringToVisibilityConverter x:Key="StrToVis"/>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <vm:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
    <StackPanel MaxWidth="720" Margin="0,8">

      <!-- ── Encabezado ── -->
      <TextBlock Text="Configuración"
                 FontSize="24" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 Margin="0,0,0,20"/>

      <!-- ── API Key (Deepseek) ── -->
      <ui:Card Padding="20" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="API Key de Deepseek"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     Margin="0,0,0,4"/>

          <!-- Indicador de key existente -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                      Visibility="{Binding TieneKey, Converter={StaticResource BoolToVis}}">
            <ui:SymbolIcon Symbol="CheckmarkCircle24"
                           Foreground="Green" Margin="0,0,6,0"/>
            <TextBlock Text="Ya hay una API key guardada."
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                      Visibility="{Binding TieneKey, Converter={StaticResource InvBoolToVis}}">
            <ui:SymbolIcon Symbol="Warning24"
                           Foreground="Orange" Margin="0,0,6,0"/>
            <TextBlock Text="No hay API key guardada."
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center"/>
          </StackPanel>

          <TextBlock Text="Ingresá la nueva API key (no se muestra la existente por seguridad):"
                     FontSize="12"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     Margin="0,0,0,8"/>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:PasswordBox Grid.Column="0"
                            PlaceholderText="sk-xxxxxxxxxxxxxxxx"
                            Password="{Binding ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Margin="0,0,8,0"/>

            <ui:Button Grid.Column="1"
                       Content="Guardar key"
                       Command="{Binding GuardarApiKeyCommand}"
                       Appearance="Primary"
                       Icon="{ui:SymbolIcon Symbol=Key24}"/>
          </Grid>
        </StackPanel>
      </ui:Card>

      <!-- ── Carpeta de salida ── -->
      <ui:Card Padding="20" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="Carpeta de salida (workspace)"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     Margin="0,0,0,8"/>
          <ui:TextBox Text="{Binding CarpetaSalida, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Ruta al workspace…"
                     FontSize="13"/>
          <TextBlock Text="Carpeta donde se guardan los análisis, archivos intermedios y PDFs generados."
                     FontSize="11"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                     Margin="0,4,0,0"/>
        </StackPanel>
      </ui:Card>

      <!-- ── DPI y Modelo ── -->
      <ui:Card Padding="20" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="Parámetros de análisis"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     Margin="0,0,0,12"/>

          <!-- DPI -->
          <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
              <TextBlock Text="DPI de rasterizado"
                         FontSize="13"
                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
              <TextBlock Text="Resolución usada para convertir PDFs en imágenes antes del OCR. Valores recomendados: 150–300."
                         FontSize="11"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                         TextWrapping="Wrap"/>
            </StackPanel>
            <ui:NumberBox Grid.Column="1"
                          Value="{Binding Dpi, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                          Minimum="72" Maximum="600"
                          SmallChange="50" LargeChange="50"
                          MaxDecimalPlaces="0"
                          ClearButtonEnabled="False"
                          SpinButtonPlacementMode="Compact"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"/>
          </Grid>

          <!-- Modelo IA -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="Modelo de IA"
                         FontSize="13"
                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
              <TextBlock Text="Identificador del modelo a usar en la API de Deepseek."
                         FontSize="11"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            </StackPanel>
            <ComboBox Grid.Column="1"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding Modelo, Mode=TwoWay}"
                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                      VerticalAlignment="Center">
              <ComboBoxItem Content="deepseek-v4-flash"/>
              <ComboBoxItem Content="deepseek-reasoner"/>
              <ComboBoxItem Content="deepseek-chat"/>
            </ComboBox>
          </Grid>
        </StackPanel>
      </ui:Card>

      <!-- ── Tema ── -->
      <ui:Card Padding="20" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="Apariencia"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     Margin="0,0,0,12"/>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <TextBlock Text="Tema oscuro"
                         FontSize="13"
                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
              <TextBlock Text="Alterna entre tema oscuro y claro en tiempo real."
                         FontSize="11"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            </StackPanel>

            <ui:ToggleSwitch Grid.Column="1"
                             IsChecked="{Binding TemaOscuro, Mode=TwoWay}"
                             Command="{Binding AplicarTemaCommand}"
                             VerticalAlignment="Center"/>
          </Grid>
        </StackPanel>
      </ui:Card>

      <!-- ── Prompts (avanzado) ── -->
      <ui:Card Padding="20" Margin="0,0,0,16">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <ui:SymbolIcon Symbol="Wand24" Margin="0,0,8,0"
                           Foreground="{DynamicResource SystemAccentColorBrush}"/>
            <TextBlock Text="Prompts (avanzado)"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock Text="Estos prompts definen el comportamiento central de la IA. Editás solo el rol/estilo; el formato de salida (que la app necesita para generar el PDF y los temas) se aplica automáticamente y no se puede romper."
                     FontSize="12" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     Margin="0,0,0,12"/>

          <!-- Limpieza -->
          <TextBlock Text="Corrección de OCR (limpieza)" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
          <ui:TextBox Text="{Binding PromptLimpieza, UpdateSourceTrigger=PropertyChanged}"
                      AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" FontSize="12"/>
          <TextBlock Text="{Binding FormatoLimpieza}" FontSize="11" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,12"/>

          <!-- Detección -->
          <TextBlock Text="Detección de temas" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
          <ui:TextBox Text="{Binding PromptDeteccion, UpdateSourceTrigger=PropertyChanged}"
                      AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" FontSize="12"/>
          <TextBlock Text="El formato JSON de salida se aplica automáticamente."
                     FontSize="11" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,12"/>

          <!-- Resumen -->
          <TextBlock Text="Resumen" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
          <ui:TextBox Text="{Binding PromptResumen, UpdateSourceTrigger=PropertyChanged}"
                      AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" FontSize="12"/>
          <TextBlock Text="{Binding FormatoResumen}" FontSize="11" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,12"/>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="Restaurar por defecto"
                       Command="{Binding RestaurarPromptsCommand}"
                       Icon="{ui:SymbolIcon Symbol=ArrowReset24}" Margin="0,0,8,0"/>
            <ui:Button Content="Guardar prompts"
                       Command="{Binding GuardarPromptsCommand}"
                       Appearance="Primary"
                       Icon="{ui:SymbolIcon Symbol=Save24}"/>
          </StackPanel>
        </StackPanel>
      </ui:Card>

      <!-- ── Botón Guardar configuración ── -->
      <ui:Button Content="Guardar configuración"
                 Command="{Binding GuardarConfigCommand}"
                 Appearance="Primary"
                 Icon="{ui:SymbolIcon Symbol=Save24}"
                 FontSize="14"
                 Height="44"
                 HorizontalAlignment="Right"
                 Margin="0,0,0,8"/>

      <!-- ── Mensaje de estado ── -->
      <TextBlock Text="{Binding MensajeEstado}"
                 FontSize="12"
                 Foreground="{DynamicResource SystemAccentColorBrush}"
                 HorizontalAlignment="Right"
                 Margin="0,0,0,20"
                 Visibility="{Binding MensajeEstado, Converter={StaticResource StrToVis}}"/>

    </StackPanel>
  </ScrollViewer>
</Page>
