<Page x:Class="Resumenes.Ui.Vistas.VistaConfigurar"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Resumenes.Ui.ViewModels"
      Title="Nuevo análisis">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <vm:StringToVisibilityConverter x:Key="StringToVisConverter"/>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
    <StackPanel MaxWidth="720" Margin="0,8">

      <ui:Button Content="Volver"
                 Command="{Binding VolverCommand}"
                 Appearance="Secondary"
                 Icon="{ui:SymbolIcon Symbol=ArrowLeft24}"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,16"/>

      <!-- Título -->
      <TextBlock Text="Nuevo análisis"
                 FontSize="24" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 Margin="0,0,0,4"/>
      <TextBlock Text="Seleccioná la carpeta con los archivos que querés analizar."
                 FontSize="13"
                 Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                 Margin="0,0,0,20"/>

      <!-- ── Selector de carpeta ── -->
      <ui:Card Padding="16,14" Margin="0,0,0,14">
        <StackPanel>
          <TextBlock Text="Carpeta de entrada"
                     FontSize="13" FontWeight="SemiBold"
                     Margin="0,0,0,10"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0"
                        PlaceholderText="(ninguna seleccionada)"
                        Text="{Binding CarpetaSeleccionada, Mode=OneWay}"
                        IsReadOnly="True"
                        Margin="0,0,8,0"
                        VerticalContentAlignment="Center"/>
            <ui:Button Grid.Column="1"
                       Content="Explorar…"
                       Command="{Binding SeleccionarCarpetaCommand}"
                       Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                       Appearance="Secondary"/>
          </Grid>
        </StackPanel>
      </ui:Card>

      <!-- ── Lista de archivos detectados ── -->
      <ui:Card Padding="16,14" Margin="0,0,0,14">
        <StackPanel>
          <TextBlock Text="Archivos detectados"
                     FontSize="13" FontWeight="SemiBold"
                     Margin="0,0,0,6"/>
          <TextBlock Text="Destildá los que no quieras procesar."
                     FontSize="11"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                     Margin="0,0,0,8"/>

          <!-- Placeholder cuando no hay carpeta -->
          <TextBlock Text="(seleccioná una carpeta para ver los archivos)"
                     FontSize="12"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                     Margin="0,4">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Archivos.Count}" Value="0">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Archivos}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ArchivoSeleccionableVm}">
                  <Border Padding="8,5" Margin="0,2" CornerRadius="4"
                          Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <CheckBox IsChecked="{Binding Incluido, Mode=TwoWay}"
                              VerticalContentAlignment="Center">
                      <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Document24" FontSize="14" Margin="0,0,8,0"
                                       Foreground="{DynamicResource SystemAccentColorBrush}"/>
                        <TextBlock Text="{Binding Nombre}" FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                      </StackPanel>
                    </CheckBox>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>
      </ui:Card>

      <!-- ── Prompt de temas ── -->
      <ui:Card Padding="16,14" Margin="0,0,0,14">
        <StackPanel>
          <TextBlock Text="Prompt de temas (opcional)"
                     FontSize="13" FontWeight="SemiBold"
                     Margin="0,0,0,6"/>
          <TextBlock Text="Si lo dejás vacío, el modelo detectará los temas automáticamente."
                     FontSize="12"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     Margin="0,0,0,10"/>
          <ui:TextBox
              PlaceholderText="Ej.: Quiero temas sobre anatomía del sistema nervioso…"
              Text="{Binding PromptTemas, UpdateSourceTrigger=PropertyChanged}"
              AcceptsReturn="True"
              TextWrapping="Wrap"
              Height="90"
              VerticalContentAlignment="Top"
              Padding="8"/>
        </StackPanel>
      </ui:Card>

      <!-- ── Error ── -->
      <TextBlock Text="{Binding MensajeError}"
                 Foreground="#e05252"
                 FontSize="12"
                 Margin="0,0,0,10"
                 Visibility="{Binding MensajeError, Converter={StaticResource StringToVisConverter}}"/>

      <!-- ── Botón Analizar ── -->
      <ui:Button Content="Analizar"
                 Command="{Binding AnalizarCommand}"
                 Appearance="Primary"
                 HorizontalAlignment="Stretch"
                 Height="44"
                 FontSize="15" FontWeight="SemiBold"
                 Icon="{ui:SymbolIcon Symbol=Play24}"/>

    </StackPanel>
  </ScrollViewer>
</Page>
