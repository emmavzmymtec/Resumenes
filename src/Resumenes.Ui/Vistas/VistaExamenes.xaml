<Page x:Class="Resumenes.Ui.Vistas.VistaExamenes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Resumenes.Ui.ViewModels"
      Title="Exámenes">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
    <StackPanel MaxWidth="860" Margin="0,8">

      <ui:Button Content="Volver"
                 Command="{Binding VolverCommand}"
                 Appearance="Secondary"
                 Icon="{ui:SymbolIcon Symbol=ArrowLeft24}"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,16"/>

      <!-- Encabezado -->
      <ui:Card Padding="24,20" Margin="0,0,0,16">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <TextBlock Text="Historial de exámenes"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="Tus exámenes simulados para este análisis."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0"/>
          </StackPanel>

          <ui:Button Grid.Column="1"
                     Content="Nuevo examen"
                     Command="{Binding NuevoExamenCommand}"
                     Appearance="Primary"
                     Icon="{ui:SymbolIcon Symbol=Add24}"
                     FontSize="14" FontWeight="SemiBold"
                     Height="44" Padding="20,0"
                     VerticalAlignment="Center"/>
        </Grid>
      </ui:Card>

      <!-- Sin exámenes -->
      <ui:Card Padding="32,28" Margin="0,0,0,8">
        <ui:Card.Style>
          <Style TargetType="ui:Card">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Examenes.Count}" Value="0">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ui:Card.Style>
        <StackPanel HorizontalAlignment="Center">
          <ui:SymbolIcon Symbol="Notebook24" FontSize="40"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
          <TextBlock Text="No hay exámenes todavía."
                     FontSize="14"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     Margin="0,12,0,4"/>
          <TextBlock Text="Hacé clic en 'Nuevo examen' para empezar."
                     FontSize="12"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
        </StackPanel>
      </ui:Card>

      <!-- Lista de exámenes -->
      <ItemsControl ItemsSource="{Binding Examenes}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:ExamenItemVm}">
            <ui:Card Margin="0,0,0,8" Padding="16,14">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Título -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Titulo}"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Fecha y nota -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                            Orientation="Horizontal" Margin="0,6,0,10">
                  <ui:SymbolIcon Symbol="Calendar24" FontSize="13"
                                 Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                 Margin="0,0,4,0"/>
                  <TextBlock Text="{Binding FechaLegible}"
                             FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                  <TextBlock Text=" · " FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                  <TextBlock Text="{Binding NotaLegible}"
                             FontSize="11"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- Botones de acción -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                            Orientation="Horizontal" HorizontalAlignment="Right">

                  <!-- Rendir (solo si en curso o borrador) -->
                  <ui:Button Content="Rendir"
                             Command="{Binding DataContext.RendirCommand,
                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                             CommandParameter="{Binding}"
                             Appearance="Primary"
                             Margin="0,0,6,0"
                             Icon="{ui:SymbolIcon Symbol=Play24}"
                             Visibility="{Binding EnCurso, Converter={StaticResource BoolToVis}}"/>

                  <!-- Ver resultado (solo si corregido) -->
                  <ui:Button Content="Ver resultado"
                             Command="{Binding DataContext.VerResultadoCommand,
                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                             CommandParameter="{Binding}"
                             Appearance="Primary"
                             Margin="0,0,6,0"
                             Icon="{ui:SymbolIcon Symbol=DocumentBulletList24}"
                             Visibility="{Binding EstaCorregido, Converter={StaticResource BoolToVis}}"/>

                  <!-- Eliminar -->
                  <ui:Button Content="Eliminar"
                             Command="{Binding DataContext.EliminarCommand,
                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                             CommandParameter="{Binding}"
                             Appearance="Secondary"
                             Icon="{ui:SymbolIcon Symbol=Delete24}"/>
                </StackPanel>
              </Grid>
            </ui:Card>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</Page>
