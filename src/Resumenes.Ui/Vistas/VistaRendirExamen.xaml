<Page x:Class="Resumenes.Ui.Vistas.VistaRendirExamen"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Resumenes.Ui.ViewModels"
      xmlns:modelos="clr-namespace:Resumenes.Core.Modelos;assembly=Resumenes.Core"
      Title="Rendir examen">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <vm:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    <vm:NullableBoolToCheckedConverter x:Key="NullableBoolToChecked"/>
    <vm:StringToVisibilityConverter x:Key="StringToVis"/>

    <!-- DataTemplate: McUna -->
    <DataTemplate x:Key="DtMcUna">
      <ItemsControl ItemsSource="{Binding Opciones}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <RadioButton Content="{Binding Texto}"
                         IsChecked="{Binding Seleccionada, Mode=TwoWay}"
                         GroupName="mcuna_group"
                         FontSize="13" Margin="0,4"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </DataTemplate>

    <!-- DataTemplate: McVarias -->
    <DataTemplate x:Key="DtMcVarias">
      <ItemsControl ItemsSource="{Binding Opciones}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <CheckBox Content="{Binding Texto}"
                      IsChecked="{Binding Seleccionada, Mode=TwoWay}"
                      FontSize="13" Margin="0,4"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </DataTemplate>

    <!-- DataTemplate: VfJustificado -->
    <DataTemplate x:Key="DtVfJustificado">
      <StackPanel>
        <TextBlock Text="{Binding Afirmacion}"
                   FontSize="13" FontStyle="Italic" TextWrapping="Wrap"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,8"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
          <RadioButton Content="Verdadero" GroupName="VF"
                       IsChecked="{Binding Vf, Converter={StaticResource NullableBoolToChecked}, ConverterParameter=True, Mode=TwoWay}"
                       FontSize="13" Margin="0,0,20,0"/>
          <RadioButton Content="Falso" GroupName="VF"
                       IsChecked="{Binding Vf, Converter={StaticResource NullableBoolToChecked}, ConverterParameter=False, Mode=TwoWay}"
                       FontSize="13"/>
        </StackPanel>
        <TextBlock Text="Justificación:" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        <TextBox Text="{Binding TextoRespuesta, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                 FontSize="13" Padding="8"/>
      </StackPanel>
    </DataTemplate>

    <!-- DataTemplate: Desarrollo -->
    <DataTemplate x:Key="DtDesarrollo">
      <TextBox Text="{Binding TextoRespuesta, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
               FontSize="13" Padding="8"/>
    </DataTemplate>

    <!-- DataTemplate: DesarrolloItems -->
    <DataTemplate x:Key="DtDesarrolloItems">
      <ItemsControl ItemsSource="{Binding Items}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="0,0,0,12">
              <TextBlock Text="{Binding Enunciado}" FontSize="13" FontWeight="SemiBold"
                         TextWrapping="Wrap" Margin="0,0,0,4"
                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
              <TextBox Text="{Binding Texto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       AcceptsReturn="True" TextWrapping="Wrap" MinHeight="70"
                       FontSize="13" Padding="8"/>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </DataTemplate>

    <!-- DataTemplate: Completar -->
    <DataTemplate x:Key="DtCompletar">
      <ItemsControl ItemsSource="{Binding Huecos}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal" Margin="0,4">
              <TextBlock Text="Hueco:" VerticalAlignment="Center" FontSize="13"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                         Margin="0,0,8,0"/>
              <TextBox Text="{Binding Valor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       MinWidth="200" FontSize="13" Padding="6,4"/>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </DataTemplate>

    <!-- DataTemplate: Emparejar -->
    <DataTemplate x:Key="DtEmparejar">
      <ItemsControl ItemsSource="{Binding EmparejamientoItems}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding TextoIzquierda}"
                         FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
              <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center"
                         HorizontalAlignment="Center" FontSize="13"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
              <ComboBox Grid.Column="2"
                        ItemsSource="{Binding Derecha}"
                        SelectedIndex="{Binding SeleccionIndice, Mode=TwoWay}"
                        FontSize="13"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </DataTemplate>

  </Page.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Encabezado: timer + progreso -->
    <Border Grid.Row="0" Padding="20,12" BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <ui:Button Content="Volver"
                     Command="{Binding VolverCommand}"
                     Appearance="Secondary"
                     Icon="{ui:SymbolIcon Symbol=ArrowLeft24}"
                     Margin="0,0,16,0"/>
          <TextBlock FontSize="15" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}">
            <Run Text="Pregunta "/>
            <Run Text="{Binding NumeroPreguntaActual, Mode=OneWay}"/>
            <Run Text=" de "/>
            <Run Text="{Binding Preguntas.Count, Mode=OneWay}"/>
          </TextBlock>
        </StackPanel>

        <!-- Marcar para revisar -->
        <CheckBox Grid.Column="1" VerticalAlignment="Center"
                  Content="Marcar para revisar"
                  IsChecked="{Binding Actual.MarcadaParaRevisar, Mode=TwoWay}"
                  FontSize="13" Margin="0,0,20,0"/>

        <!-- Timer -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <ui:SymbolIcon Symbol="Timer24" FontSize="16" Margin="0,0,6,0"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
          <TextBlock Text="{Binding TextoTiempo}" FontSize="16" FontWeight="SemiBold"
                     FontFamily="Cascadia Code, Consolas, monospace"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Área de pregunta -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
      <StackPanel MaxWidth="780" Margin="0,8">

        <!-- Enunciado -->
        <TextBlock Text="{Binding Actual.Enunciado}"
                   FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                   Margin="0,0,0,4"/>
        <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,16">
          <Run Text="{Binding Actual.Puntos, Mode=OneWay, StringFormat='{}{0:0.##}'}"/>
          <Run Text=" pts"/>
        </TextBlock>

        <!-- Área de respuesta por tipo (DataTriggers) -->
        <ContentControl Content="{Binding Actual}">
          <ContentControl.Style>
            <Style TargetType="ContentControl">
              <Setter Property="ContentTemplate" Value="{StaticResource DtDesarrollo}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding Actual.Tipo}" Value="{x:Static modelos:TipoPregunta.McUna}">
                  <Setter Property="ContentTemplate" Value="{StaticResource DtMcUna}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Actual.Tipo}" Value="{x:Static modelos:TipoPregunta.McVarias}">
                  <Setter Property="ContentTemplate" Value="{StaticResource DtMcVarias}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Actual.Tipo}" Value="{x:Static modelos:TipoPregunta.VfJustificado}">
                  <Setter Property="ContentTemplate" Value="{StaticResource DtVfJustificado}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Actual.Tipo}" Value="{x:Static modelos:TipoPregunta.DesarrolloItems}">
                  <Setter Property="ContentTemplate" Value="{StaticResource DtDesarrolloItems}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Actual.Tipo}" Value="{x:Static modelos:TipoPregunta.Completar}">
                  <Setter Property="ContentTemplate" Value="{StaticResource DtCompletar}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Actual.Tipo}" Value="{x:Static modelos:TipoPregunta.Emparejar}">
                  <Setter Property="ContentTemplate" Value="{StaticResource DtEmparejar}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ContentControl.Style>
        </ContentControl>

      </StackPanel>
    </ScrollViewer>

    <!-- Botones de navegación -->
    <Border Grid.Row="2" Padding="20,12" BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
      <StackPanel>
        <TextBlock Text="{Binding MensajeError}"
                   FontSize="13" Foreground="#e05252" TextWrapping="Wrap"
                   Visibility="{Binding MensajeError, Converter={StaticResource StringToVis}}"
                   Margin="0,0,0,8"/>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <ui:Button Grid.Column="0"
                   Content="Anterior"
                   Command="{Binding AnteriorCommand}"
                   Icon="{ui:SymbolIcon Symbol=ChevronLeft24}"
                   Appearance="Secondary"
                   MinWidth="110" Height="40"/>

        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
          <!-- mini mapa de preguntas (dots) -->
        </StackPanel>

        <ui:Button Grid.Column="2"
                   Content="Siguiente"
                   Command="{Binding SiguienteCommand}"
                   Icon="{ui:SymbolIcon Symbol=ChevronRight24}"
                   Appearance="Secondary"
                   MinWidth="110" Height="40" Margin="0,0,12,0"/>

        <ui:Button Grid.Column="3"
                   Content="Entregar"
                   Command="{Binding EntregarCommand}"
                   Icon="{ui:SymbolIcon Symbol=CheckmarkCircle24}"
                   Appearance="Primary"
                   MinWidth="130" Height="40"
                   Visibility="{Binding Entregando, Converter={StaticResource InvBoolToVis}}"/>

        <ui:ProgressRing Grid.Column="3"
                         IsIndeterminate="True"
                         Width="32" Height="32"
                         Visibility="{Binding Entregando, Converter={StaticResource BoolToVis}}"/>
      </Grid>
      </StackPanel>
    </Border>
  </Grid>
</Page>
