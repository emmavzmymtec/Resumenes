<Page x:Class="Resumenes.Ui.Vistas.VistaResultadoExamen"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Resumenes.Ui.ViewModels"
      Title="Resultado del examen">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <vm:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    <vm:StringToVisibilityConverter x:Key="StringToVis"/>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="820" Margin="32,24" HorizontalAlignment="Center">

      <!-- Encabezado: título del examen -->
      <TextBlock Text="{Binding Titulo}" FontSize="20" FontWeight="Bold"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 TextWrapping="Wrap" Margin="0,0,0,20"/>

      <!-- Tarjeta de resumen -->
      <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,20">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Orientation="Vertical">
            <!-- Nota grande -->
            <TextBlock Text="{Binding NotaLegible}" FontSize="32" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <!-- Porcentaje -->
            <TextBlock Text="{Binding PorcentajeLegible}" FontSize="15"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0"/>
          </StackPanel>

          <!-- Chip Aprobado / Desaprobado -->
          <Border Grid.Column="1" CornerRadius="16" Padding="16,8" VerticalAlignment="Center">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Background" Value="#FFD32F2F"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Aprobado}" Value="True">
                    <Setter Property="Background" Value="#FF2E7D32"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Text" Value="Desaprobado"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Aprobado}" Value="True">
                      <Setter Property="Text" Value="Aprobado"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Border>
        </Grid>
      </Border>

      <!-- Feedback general -->
      <Border Visibility="{Binding FeedbackGeneral, Converter={StaticResource StringToVis}}"
              Background="{DynamicResource ControlFillColorSecondaryBrush}"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1" CornerRadius="6" Padding="16,12" Margin="0,0,0,24">
        <StackPanel>
          <TextBlock Text="Comentario general" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6"/>
          <TextBlock Text="{Binding FeedbackGeneral}" FontSize="13" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        </StackPanel>
      </Border>

      <!-- Título desglose -->
      <TextBlock Text="Desglose por pregunta" FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,12"/>

      <!-- Lista de preguntas -->
      <ItemsControl ItemsSource="{Binding Detalle}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,0,10"
                    BorderThickness="1" CornerRadius="6" Padding="16,12">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                  <Setter Property="BorderBrush" Value="#FFD32F2F"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding EsCorrecta}" Value="True">
                      <Setter Property="BorderBrush" Value="#FF2E7D32"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Ícono correcto/incorrecto -->
                <ui:SymbolIcon Grid.Column="0" VerticalAlignment="Top" Margin="0,2,12,0" FontSize="20">
                  <ui:SymbolIcon.Style>
                    <Style TargetType="ui:SymbolIcon">
                      <Setter Property="Symbol" Value="DismissCircle24"/>
                      <Setter Property="Foreground" Value="#FFD32F2F"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding EsCorrecta}" Value="True">
                          <Setter Property="Symbol" Value="CheckmarkCircle24"/>
                          <Setter Property="Foreground" Value="#FF2E7D32"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </ui:SymbolIcon.Style>
                </ui:SymbolIcon>

                <StackPanel Grid.Column="1">
                  <!-- Enunciado -->
                  <TextBlock Text="{Binding Enunciado}" FontSize="13" FontWeight="SemiBold"
                             TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                             Margin="0,0,0,6"/>

                  <!-- Puntaje -->
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Puntaje: " FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{Binding PuntajeLegible}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                  </StackPanel>

                  <!-- Feedback IA -->
                  <TextBlock Text="{Binding Feedback}" FontSize="12" TextWrapping="Wrap"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             Margin="0,4,0,0"
                             Visibility="{Binding Feedback, Converter={StaticResource StringToVis}}"/>

                  <!-- Marca ambigua -->
                  <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                              Visibility="{Binding Ambigua, Converter={StaticResource BoolToVis}}">
                    <ui:SymbolIcon Symbol="Warning24" FontSize="13"
                                   Foreground="#FFE65100" Margin="0,0,4,0"/>
                    <TextBlock Text="Pregunta marcada como ambigua" FontSize="12"
                               Foreground="#FFE65100"/>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Botón Reintentar -->
      <ui:Button Content="Reintentar examen"
                 Command="{Binding ReintentarCommand}"
                 Icon="{ui:SymbolIcon Symbol=ArrowRepeatAll24}"
                 Appearance="Primary"
                 HorizontalAlignment="Center"
                 MinWidth="200" Height="44"
                 Margin="0,24,0,32"/>

    </StackPanel>
  </ScrollViewer>
</Page>
